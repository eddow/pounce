{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"types": ["node", "vitest/globals"],
		"noEmit": true,
		"baseUrl": "../..",
		"paths": {
			"@pounce/kit": ["test/ep.ts"]
		}
	},
	"include": [
		"../src/**/*.ts",
		"../src/**/*.tsx",
		"./**/*.ts",
		"./**/*.tsx"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}

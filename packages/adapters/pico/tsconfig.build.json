{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"rootDir": "../../../../",
		"paths": {
			"@sursaut/core": ["../../core/dist/index"],
			"@sursaut/core/*": ["../../core/dist/*"],
			"@sursaut/kit": ["../../kit/dist/dom"],
			"@sursaut/kit/*": ["../../kit/dist/*"],
			"@sursaut/ui": ["../../ui/dist/index"],
			"@sursaut/ui/*": ["../../ui/dist/*"],
			"@sursaut/ui/models": ["../../ui/dist/models/index"],
			"mutts": ["../../../../mutts/dist/browser"],
			"mutts/*": ["../../../../mutts/dist/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["dist", "demo", "node_modules"]
}

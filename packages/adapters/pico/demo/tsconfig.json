{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"baseUrl": ".",
		"rootDir": "../../../../../",
		"paths": {
			"@sursaut/core": [
				"../../../core/src/index.ts"
			],
			"@sursaut/core/*": [
				"../../../core/src/*"
			],
			"@sursaut/kit": [
				"../../../kit/src/index.ts"
			],
			"@sursaut/kit/*": [
				"../../../kit/src/*"
			],
			"@sursaut/ui": [
				"../../../ui/src/index.ts"
			],
			"@sursaut/ui/*": [
				"../../../ui/src/*"
			],
			"@sursaut/ui/models": [
				"../../../ui/src/models/index.ts"
			],
			"mutts": [
				"../../../../../mutts/src/index.ts"
			],
			"mutts/*": [
				"../../../../../mutts/src/*"
			],
			"@sursaut/adapter-pico": [
				"../src/index.ts"
			],
			"@sursaut/adapter-pico/css": [
				"../src/pico.sass"
			]
		}
	},
	"include": [
		"./**/*",
		"../src/**/*"
	]
}

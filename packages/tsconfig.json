{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"allowJs": true,
		"strict": true,
		"noEmit": true,
		"types": [],
		"lib": [
			"ESNext",
			"DOM",
			"DOM.Iterable"
		],
		"jsx": "react",
		"jsxFactory": "h",
		"jsxFragmentFactory": "Fragment",
		"paths": {
			"@sursaut/core": [
				"./core/src"
			],
			"@sursaut/core/testing": [
				"./core/src/testing/index.ts"
			],
			"@sursaut/core/*": [
				"./core/src/*"
			],
			"@sursaut/ui": [
				"./ui/src"
			],
			"@sursaut/ui/*": [
				"./ui/src/*"
			],
			"@sursaut/kit": [
				"./kit/src"
			],
			"@sursaut/kit/*": [
				"./kit/src/*"
			]
		}
	},
	"exclude": [
		"node_modules",
		"dist",
		"build"
	]
}
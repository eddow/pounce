{
	"name": "@sursaut/ui",
	"version": "1.0.0",
	"description": "Headless UI primitives for Sursaut applications",
	"type": "module",
	"sideEffects": false,
	"keywords": [
		"sursaut",
		"headless",
		"ui",
		"components",
		"primitives"
	],
	"author": "fmdm",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/eddow/sursaut.git"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./dockview": {
			"types": "./dist/dockview.d.ts",
			"import": "./dist/dockview.js",
			"default": "./dist/dockview.js"
		},
		"./palette": {
			"types": "./dist/palette.d.ts",
			"import": "./dist/palette.js",
			"default": "./dist/palette.js"
		},
		"./models": {
			"types": "./dist/models/index.d.ts",
			"import": "./dist/models.js",
			"default": "./dist/models.js"
		},
		"./styles/*": "./src/styles/*"
	},
	"files": [
		"dist",
		"src",
		"!src/**/*.spec.*",
		"!src/**/*.test.*",
		"!demo",
		"!tests",
		"README.md",
		"LLM.md"
	],
	"scripts": {
		"build": "vite build",
		"demo": "tsc --project demo/tsconfig.json && vite --port 5270",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@sursaut/core": "workspace:*",
		"@sursaut/kit": "workspace:*",
		"mutts": "^1.0.13"
	},
	"peerDependencies": {
		"dockview-core": "^5.0.0"
	},
	"peerDependenciesMeta": {
		"dockview-core": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/node": "^25.1.0",
		"dockview-core": "^5.0.0",
		"jsdom": "^27.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-dts": "^4.5.3",
		"vitest": "^4.0.18"
	},
	"packageManager": "pnpm@10.30.0"
}
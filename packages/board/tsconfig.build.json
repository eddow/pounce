{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"declarationMap": true,
		"outDir": "./dist",
		"baseUrl": ".",
		"jsx": "react",
		"jsxFactory": "h",
		"jsxFragmentFactory": "Fragment",
		"lib": [
			"ES2022",
			"DOM",
			"DOM.Iterable"
		],
		"types": [
			"node",
			"@sursaut/core"
		],
		"paths": {
			"~/lib/*": [
				"./src/lib/*"
			],
			"~/adapters/*": [
				"./src/adapters/*"
			],
			"~/cli/*": [
				"./src/cli/*"
			],
			"sursaut-board": [
				"./src/server/index.ts"
			],
			"sursaut-board/client": [
				"./src/client/index.ts"
			],
			"sursaut-board/server": [
				"./src/server/index.ts"
			],
			"sursaut-ts": [
				"../core/src/lib/index.ts"
			],
			"sursaut-ts/*": [
				"../core/src/*"
			],
			"sursaut-ui": [
				"../ui/src/index.ts"
			],
			"sursaut-ui/*": [
				"../ui/src/*"
			],
			"@sursaut/kit": [
				"../kit/src/index.ts"
			],
			"@sursaut/kit/*": [
				"../kit/src/*"
			],
			"@sursaut/board": [
				"./src/index.ts"
			],
			"@sursaut/board/*": [
				"./src/*"
			],
			"mutts": [
				"../../../mutts/dist/index.d.ts"
			]
		}
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"node_modules",
		"dist",
		"tests",
		"demo"
	]
}